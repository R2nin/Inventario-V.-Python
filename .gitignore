# Variáveis de ambiente (contém senhas!)
.env

# Arquivos compilados do Python
__pycache__/
*.py[cod]
*.pyo

# Ambiente virtual Python
venv/
env/
.venv/

# Banco de dados SQLite (usado apenas em dev local simples)
