db.sqlite3

# Arquivos de mídia enviados por usuários
media/

# Arquivos estáticos coletados (gerados pelo collectstatic)
staticfiles/

# Configurações do editor de código
.vscode/
.idea/
*.swp

# Sistema operacional
.DS_Store
Thumbs.db

# Logs
*.log
