# ============================================================
# VARIÁVEIS DE AMBIENTE - copie este arquivo para ".env"
# e preencha com os seus dados reais
# ============================================================
# IMPORTANTE: O arquivo ".env" NUNCA deve ser enviado ao GitHub!
#             Ele contém senhas e chaves secretas.

# --- Django ---
# Chave secreta do Django (gere uma em: https://djecrety.ir/)
SECRET_KEY=sua-chave-secreta-django-aqui

# DEBUG: True durante desenvolvimento, False em produção
DEBUG=True

# Hosts permitidos (em produção, coloque o domínio do seu site)
# Exemplo produção: ALLOWED_HOSTS=meusite.railway.app,meudominio.com
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Banco de dados Supabase (PostgreSQL) ---
# Encontre estes dados em: Supabase > Settings > Database > Connection string
# Use a connection string no formato:
# postgresql://postgres:[SUA-SENHA]@db.[SEU-PROJETO].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:SUA_SENHA@db.SEU_PROJETO.supabase.co:5432/postgres

# --- Supabase (opcional - para funcionalidades extras) ---
# Encontre em: Supabase > Settings > API
SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_ANON_KEY=sua-chave-anonima-do-supabase
